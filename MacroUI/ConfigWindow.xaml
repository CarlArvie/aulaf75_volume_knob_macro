<Window x:Class="MacroUI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Aula Macro Configuration" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="10,10,10,0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border Name="Border" Padding="15,8" Margin="0,0,5,0" Background="#333333" CornerRadius="6,6,0,0">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#007ACC" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#005A9E" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </TabControl.Resources>

        <TabItem Header="⭕ Circular Menu">
            <Grid Margin="10,20,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="200"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Tree View -->
                <Grid Grid.Column="0" MouseDown="LeftPanel_MouseDown" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Macro Hierarchy" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#007ACC"/>
                    
                    <TextBox x:Name="MacroSearchBox" Grid.Row="1" TextChanged="MacroSearchBox_TextChanged" Margin="0,0,0,10" Padding="8" Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42" BorderThickness="1"/>
                    <TextBlock Grid.Row="1" Text="🔍 Search Macros..." IsHitTestVisible="False" Foreground="#888" Margin="8,8,0,0" x:Name="MacroSearchPlaceholder"/>

                    <Border Grid.Row="2" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Background="#252526" Margin="0,0,0,15">
                        <TreeView x:Name="MacroTreeView" SelectedItemChanged="MacroTreeView_SelectedItemChanged" BorderThickness="0" Background="Transparent" AllowDrop="True" PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown" MouseMove="TreeView_MouseMove" DragEnter="TreeView_DragEnter" Drop="TreeView_Drop">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2,4" Background="Transparent">
                                        <StackPanel.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="✏️ Edit" Click="EditNode_Click"/>
                                                <Separator/>
                                                <MenuItem Header="📁 Add Category" Click="AddCategory_Click"/>
                                                <MenuItem Header="⚡ Add Macro" Click="AddMacro_Click"/>
                                                <Separator/>
                                                <MenuItem Header="🗑️ Delete" Click="Delete_Click" Foreground="#C50B0B"/>
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Border>
                    
                    <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Stretch" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="📁 + Category" Click="AddCategory_Click"/>
                            <Button Content="⚡ + Macro" Click="AddMacro_Click"/>
                        </StackPanel>
                        <TextBlock Text="Menu Center Title" FontSize="14" FontWeight="SemiBold" Foreground="#888" Margin="0,15,0,5" HorizontalAlignment="Center"/>
                        <TextBox x:Name="CenterTitleTextBox" Text="AULA" Width="200" HorizontalAlignment="Center" TextAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="#007ACC" TextChanged="CenterTitle_TextChanged"/>

                        <TextBlock Text="Menu Center Logo" FontSize="14" FontWeight="SemiBold" Foreground="#888" Margin="0,15,0,5" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CenterLogoTextBlock" Text="No logo selected." FontSize="12" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🖼️ Browse Logo" Click="BrowseCenterLogo_Click" Padding="10,5" FontSize="12"/>
                            <Button Content="❌ Clear Logo" Click="ClearCenterLogo_Click" Padding="10,5" FontSize="12" Background="#A22"/>
                        </StackPanel>

                        <TextBlock Text="Menu Select Key" FontSize="14" FontWeight="SemiBold" Foreground="#888" Margin="0,15,0,5" HorizontalAlignment="Center"/>
                        <ComboBox x:Name="SelectKeyComboBox" Width="200" HorizontalAlignment="Center" IsEditable="True">
                            <ComboBoxItem Content="LButton"/>
                            <ComboBoxItem Content="RButton"/>
                            <ComboBoxItem Content="MButton"/>
                            <ComboBoxItem Content="Volume_Mute"/>
                            <ComboBoxItem Content="Space"/>
                            <ComboBoxItem Content="Enter"/>
                        </ComboBox>
                        
                        <TextBlock Text="Menu Back Key" FontSize="14" FontWeight="SemiBold" Foreground="#888" Margin="0,10,0,5" HorizontalAlignment="Center"/>
                        <ComboBox x:Name="BackKeyComboBox" Width="200" HorizontalAlignment="Center" IsEditable="True">
                            <ComboBoxItem Content="LButton"/>
                            <ComboBoxItem Content="RButton"/>
                            <ComboBoxItem Content="MButton"/>
                            <ComboBoxItem Content="Volume_Mute"/>
                            <ComboBoxItem Content="Space"/>
                            <ComboBoxItem Content="Enter"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#333" Cursor="SizeWE"/>

                <!-- Right Panel: Editor -->
                <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="30" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                            <TextBlock Text="⚙️" FontSize="48" HorizontalAlignment="Center" Foreground="#555" Margin="0,0,0,15"/>
                            <TextBlock Text="Select an item to edit" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock Text="Or create a new category/macro from the left panel." FontSize="14" Foreground="#555" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Editor -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                            <StackPanel x:Name="EditorPanel" Visibility="Hidden">
                                <TextBlock Text="Edit Node" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#007ACC"/>
                                
                                <TextBlock Text="Display Name" FontSize="14" FontWeight="SemiBold"/>
                                <TextBox x:Name="NameTextBox" TextChanged="Field_TextChanged" FontSize="15" Padding="10"/>

                                <TextBlock Text="Macro Type" FontSize="14" FontWeight="SemiBold"/>
                                <ComboBox x:Name="TypeComboBox" SelectionChanged="TypeComboBox_SelectionChanged" Margin="0,5,0,20" FontSize="15" Padding="8" Background="#2D2D30" Foreground="Black">
                                    <ComboBoxItem Content="📁 Category (Folder)" Tag="Category"/>
                                    <ComboBoxItem Content="⌨️ Keystroke Shortcut" Tag="Send"/>
                                    <ComboBoxItem Content="🚀 Run Program / Website" Tag="Run"/>
                                    <ComboBoxItem Content="📝 Paste Auto-Text" Tag="SendText"/>
                                    <ComboBoxItem Content="🛠️ Raw AHK Script" Tag="RawAHK"/>
                                    <ComboBoxItem Content="💻 System Command" Tag="SystemCommand"/>
                                </ComboBox>

                                <CheckBox x:Name="SecureMacroCheckBox" Content="🔒 Encrypt Payload on Disk" IsChecked="{Binding IsSelectedNode.IsSecure, ElementName=RootWindow}" Foreground="#FFF" Margin="0,0,0,15" ToolTip="If checked, the payload string will be AES-encrypted in the macros.json file."/>
                                <StackPanel x:Name="TargetProcessPanel" Visibility="Collapsed" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target Process" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Enter the executable name (e.g., chrome.exe). This category will automatically open when this app is active."/>
                                    </StackPanel>
                                    <TextBox x:Name="TargetProcessTextBox" TextChanged="ProcessOrHotkey_TextChanged" FontSize="15" Padding="10" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="TriggerHotkeyPanel" Visibility="Collapsed" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Direct Trigger Hotkey" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Assign a hotkey to run this macro instantly without opening the radial menu. Use modifiers: ^ (Ctrl), + (Shift), ! (Alt). Example: ^+a for Ctrl+Shift+A."/>
                                    </StackPanel>
                                    <TextBox x:Name="TriggerHotkeyTextBox" TextChanged="ProcessOrHotkey_TextChanged" FontSize="15" Padding="10" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="KeystrokePanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Keys to Press" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Enter AutoHotkey keystrokes. Use modifiers: ^ (Ctrl), + (Shift), ! (Alt), # (Win). Example: ^c to copy."/>
                                    </StackPanel>
                                    <TextBox x:Name="KeystrokeTextBox" TextChanged="RawField_TextChanged" FontSize="15" Padding="10" FontFamily="Consolas" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="ProgramPanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Program Path or URL" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Enter an absolute path (C:\Programs\app.exe) or a website URL (https://google.com)."/>
                                    </StackPanel>
                                    <TextBox x:Name="ProgramTextBox" TextChanged="RawField_TextChanged" FontSize="15" Padding="10" FontFamily="Consolas" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="TextPanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Text to Paste" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Enter plain text to automatically type out when triggered."/>
                                    </StackPanel>
                                    <TextBox x:Name="TextTextBox" TextChanged="RawField_TextChanged" FontSize="15" Padding="10" AcceptsReturn="True" Height="120" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="RawAHKPanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Raw AutoHotkey Script" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Write a full, multi-line AutoHotkey script. It will be saved to a temporary file and executed natively."/>
                                    </StackPanel>
                                    <Border BorderBrush="#444" BorderThickness="1" Margin="0,5,0,0" Height="200">
                                        <avalonEdit:TextEditor x:Name="RawAHKEditor" 
                                                               FontFamily="Consolas" 
                                                               FontSize="14" 
                                                               ShowLineNumbers="True" 
                                                               Background="#1E1E1E" 
                                                               Foreground="#D4D4D4"
                                                               TextChanged="RawAHKEditor_TextChanged"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="SystemCommandPanel" Visibility="Collapsed">
                                    <TextBlock Text="Select System Command" FontSize="14" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="SystemCommandComboBox" SelectionChanged="SystemCommandComboBox_SelectionChanged" FontSize="15" Padding="8" Margin="0,5,0,0">
                                        <ComboBoxItem Content="Lock Computer" Tag="LockComputer"/>
                                        <ComboBoxItem Content="Sleep Computer" Tag="SleepComputer"/>
                                        <ComboBoxItem Content="Mute/Unmute Audio" Tag="MuteAudio"/>
                                        <ComboBoxItem Content="Turn Off Display" Tag="TurnOffDisplay"/>
                                        <ComboBoxItem Content="Play/Pause Media" Tag="PlayPauseMedia"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Built-in Icon" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Select a scalable vector icon to display on the menu slice."/>
                                    </StackPanel>
                                    <ComboBox x:Name="IconLibraryComboBox" SelectionChanged="IconLibraryComboBox_SelectionChanged" FontFamily="Segoe UI Symbol" FontSize="18" Padding="8" Margin="0,5,0,0">
                                        <ComboBoxItem Content="None" Tag=""/>
                                        <ComboBoxItem Content="⚙️ Settings" Tag="⚙️"/>
                                        <ComboBoxItem Content="🌐 Web" Tag="🌐"/>
                                        <ComboBoxItem Content="📂 Folder" Tag="📂"/>
                                        <ComboBoxItem Content="🎵 Music" Tag="🎵"/>
                                        <ComboBoxItem Content="🎮 Game" Tag="🎮"/>
                                        <ComboBoxItem Content="💬 Chat" Tag="💬"/>
                                        <ComboBoxItem Content="📸 Camera" Tag="📸"/>
                                        <ComboBoxItem Content="📝 Edit" Tag="📝"/>
                                        <ComboBoxItem Content="🔍 Search" Tag="🔍"/>
                                        <ComboBoxItem Content="⭐ Star" Tag="⭐"/>
                                        <ComboBoxItem Content="🔥 Fire" Tag="🔥"/>
                                        <ComboBoxItem Content="🚀 Rocket" Tag="🚀"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Slice Background Image" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="❓" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" ToolTip="Select an image to display in this macro's pie slice in the radial menu."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button Content="Browse Image..." Click="BrowseImage_Click" Padding="10,5" />
                                        <Button Content="Clear Image" Click="ClearImage_Click" Padding="10,5" Margin="5,0,0,0" Background="#333" Foreground="#CCC" />
                                    </StackPanel>
                                    <TextBlock x:Name="ImagePathTextBlock" Text="No image selected." FontSize="12" Foreground="#888" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Margin="0,20,0,0">
                                    <Button Content="🗑️ Delete Node" Background="#C50B0B" HorizontalAlignment="Left" Click="Delete_Click" Padding="20,12" FontSize="14"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="📝 Text Autofill (Hotstrings)">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Text Autofill &amp; Hotstrings" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                    <TextBlock Text="Type an abbreviation anywhere to instantly expand it into a full text snippet or image." FontSize="14" Foreground="#888" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock Text="Tip: Use %A_YYYY% for the year, or %Clipboard% for your current clipboard text. Use [CURSOR] to automatically backspace the cursor after pasting." FontSize="12" Foreground="#888" Margin="0,0,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBox x:Name="HotstringSearchBox" Grid.Row="1" TextChanged="HotstringSearchBox_TextChanged" Margin="0,0,0,10" Padding="8" Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42" BorderThickness="1"/>
                <TextBlock Grid.Row="1" Text="🔍 Search Hotstrings..." IsHitTestVisible="False" Foreground="#888" Margin="8,8,0,0" x:Name="HotstringSearchPlaceholder"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HotstringsList" ItemsSource="{Binding Hotstrings, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252526" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="Trigger Word (e.g. .email)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8" Margin="0,0,0,10"/>
                                            <CheckBox Content="Match Typed Case" IsChecked="{Binding MatchTypedCase, Mode=TwoWay}" Foreground="#CCC" ToolTip="If checked, typing .EMAIL outputs upper-case. If unchecked, trigger is strictly case-sensitive." Margin="0,0,0,5"/>
                                            <CheckBox Content="🔒 Encrypt on Disk" IsChecked="{Binding IsSecure, Mode=TwoWay}" Foreground="#CCC" ToolTip="If checked, the replacement string will be AES-encrypted in hotstrings.json."/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                            <TextBlock Text="Replacement Text" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Replacement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontSize="14" Padding="8" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Or attach image:" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <Button Content="🖼️ Browse" Click="BrowseHotstringImage_Click" Padding="5,2" FontSize="12" Background="#444" Foreground="#EEE"/>
                                                <Button Content="❌ Clear" Click="ClearHotstringImage_Click" Padding="5,2" FontSize="12" Background="#A22" Foreground="#EEE" Margin="5,0,0,0"/>
                                                <TextBlock Text="{Binding ImagePath}" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="10,0,0,0" MaxWidth="150" TextTrimming="CharacterEllipsis" ToolTip="{Binding ImagePath}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="🗑️ Delete" Background="#C50B0B" Foreground="White" Padding="12,8" VerticalAlignment="Center" Click="DeleteHotstring_Click" Cursor="Hand" Margin="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <Button Grid.Row="3" Content="➕ Add New Snippet" Background="#28A745" Foreground="White" Padding="20,12" FontWeight="Bold" FontSize="14" HorizontalAlignment="Left" Click="AddHotstring_Click" Margin="0,5,0,0"/>
            </Grid>
        </TabItem>

        <TabItem x:Name="AestheticsTab" Header="🎨 Aesthetics">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20" Width="400" HorizontalAlignment="Left">
                    <TextBlock Text="Global Aesthetics &amp; Behavior" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                    <TextBlock Text="Customize the look and feel of the circular menu." FontSize="14" Foreground="#888" Margin="0,0,0,25"/>

                    <TextBlock Text="Color Theme" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SettingsThemeComboBox" SelectedValuePath="Tag" SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="15" Padding="8" Margin="0,0,0,20">
                        <ComboBoxItem Content="Cyberpunk Cyan" Tag="Cyberpunk Cyan"/>
                        <ComboBoxItem Content="Crimson Red" Tag="Crimson Red"/>
                        <ComboBoxItem Content="Toxic Green" Tag="Toxic Green"/>
                        <ComboBoxItem Content="Royal Purple" Tag="Royal Purple"/>
                        <ComboBoxItem Content="Amethyst" Tag="Amethyst"/>
                    </ComboBox>

                    <TextBlock Text="Animation Style" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SettingsAnimationComboBox" SelectedValuePath="Tag" SelectedValue="{Binding AnimationEasing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="15" Padding="8" Margin="0,0,0,20">
                        <ComboBoxItem Content="Smooth (Ease Out)" Tag="Smooth"/>
                        <ComboBoxItem Content="Bouncy (Elastic)" Tag="Elastic"/>
                        <ComboBoxItem Content="Linear" Tag="Linear"/>
                        <ComboBoxItem Content="Overshoot (Back)" Tag="Back"/>
                        <ComboBoxItem Content="Cubic (Fast to slow)" Tag="Cubic"/>
                        <ComboBoxItem Content="Bounce (Ball drop)" Tag="Bounce"/>
                    </ComboBox>
                    <TextBlock Text="Audio Feedback" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,10,0,5"/>
                    <CheckBox Content="🎵 Enable Audio/Haptic Feedback" IsChecked="{Binding EnableAudio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF" Margin="0,5,0,10"/>
                    
                    <StackPanel Visibility="{Binding EnableAudio, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Menu Navigation Tick Sound" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding TickSoundPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14" IsReadOnly="True" Background="#222" Foreground="#888"/>
                            <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseTickSoundCommand}" Margin="10,0,0,0" Padding="15,0" Background="#333" Foreground="#FFF"/>
                            <Button Grid.Column="2" Content="❌ Clear" Command="{Binding ClearTickSoundCommand}" Margin="10,0,0,0" Padding="15,0" Background="#A22" Foreground="#FFF" ToolTip="Remove the sound"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Volume" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding TickSoundVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" ToolTip="Adjust the haptic feedback volume"/>
                        </Grid>
                    </StackPanel>
                    <TextBlock Text="Performance &amp; Security" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,10,0,5"/>
                    <CheckBox x:Name="EnableAutoSelectCheckBox" Content="⏱️ Enable Auto-Select (Timeout)" IsChecked="{Binding EnableAutoSelect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF" ToolTip="Automatically executes the selected macro after half a second of inactivity." Margin="0,5,0,5"/>
                    <CheckBox x:Name="EnableGameModeCheckBox" Content="🎮 Enable Fullscreen Game Mode" IsChecked="{Binding EnableGameMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFF" ToolTip="Automatically suspends macros when a fullscreen application (like a game) is in focus." Margin="0,5,0,20"/>

                    <TextBlock Text="Library Management" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,30,0,5"/>
                    <TextBlock Text="Backup and restore your macros and hotstrings." FontSize="14" Foreground="#888" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📦 Export Backup (.zip)" Background="#007ACC" Command="{Binding ExportBackupCommand}" Padding="15,8" Margin="0,0,10,0"/>
                        <Button Content="📥 Import Backup (.zip)" Background="#28A745" Command="{Binding ImportBackupCommand}" Padding="15,8"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        </TabControl>

        <!-- Bottom Bar -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="15,10" BorderBrush="#3E3E42" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="💾 Save All Settings" Background="#007ACC" Click="SaveAll_Click" Padding="30,12" FontWeight="Bold" FontSize="15" Margin="0,0,15,0"/>
                <Button x:Name="UndoButton" Content="↩️ Undo Delete" Background="#555" Click="Undo_Click" Padding="15,12" FontSize="14" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
