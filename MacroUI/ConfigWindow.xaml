<Window x:Class="MacroUI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aula Macro Configuration" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Tree View -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Macro Hierarchy" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#007ACC"/>
            
            <Border Grid.Row="1" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Background="#252526" Margin="0,0,0,15">
                <TreeView x:Name="MacroTreeView" SelectedItemChanged="MacroTreeView_SelectedItemChanged" BorderThickness="0" Background="Transparent">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="📁 + Category" Click="AddCategory_Click"/>
                <Button Content="⚡ + Macro" Click="AddMacro_Click"/>
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#333" Cursor="SizeWE"/>

        <!-- Right Panel: Editor -->
        <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="30" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                    <TextBlock Text="⚙️" FontSize="48" HorizontalAlignment="Center" Foreground="#555" Margin="0,0,0,15"/>
                    <TextBlock Text="Select an item to edit" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Or create a new category/macro from the left panel." FontSize="14" Foreground="#555" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Editor -->
                <StackPanel x:Name="EditorPanel" Visibility="Hidden">
                    <TextBlock Text="Edit Node" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#007ACC"/>
                    
                    <TextBlock Text="Display Name" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox x:Name="NameTextBox" TextChanged="Field_TextChanged" FontSize="15" Padding="10"/>

                    <TextBlock Text="Action Command (Leave blank for categories)" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox x:Name="ActionTextBox" TextChanged="Field_TextChanged" FontSize="15" Padding="10" FontFamily="Consolas"/>
                    
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="15" Margin="0,10,0,0" BorderBrush="#333" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Command Syntax Guide:" FontWeight="Bold" Margin="0,0,0,10" Foreground="#AAA"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="send:^c" FontFamily="Consolas" Foreground="#569CD6" Margin="0,0,15,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Send Ctrl+C (Copy)" Foreground="#888"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="send:{Media_Play_Pause}" FontFamily="Consolas" Foreground="#569CD6" Margin="0,0,15,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Toggle Playback" Foreground="#888"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="run:notepad.exe" FontFamily="Consolas" Foreground="#569CD6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Launch an application" Foreground="#888"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,40,0,0">
                        <Button Content="🗑️ Delete Node" Background="#C50B0B" HorizontalAlignment="Left" Click="Delete_Click" Padding="20,12" FontSize="14"/>
                        <Button Content="💾 Save &amp; Apply Changes" Background="#007ACC" HorizontalAlignment="Right" Click="Save_Click" Padding="20,12" FontWeight="Bold" FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
